# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/stocksage

# Redis (local dev)
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# News & Sentiment
NEWS_API_KEY=your_newsapi_key_here

# Macro data — FRED (free at fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_key_here

# Model storage — HuggingFace Hub (free at huggingface.co)
HF_TOKEN=hf_your_token_here
HF_REPO_ID=your-username/stocksage-models

# Model artifacts (local fallback)
MODEL_ARTIFACTS_DIR=./models
MLFLOW_TRACKING_URI=http://localhost:5000

# App secrets — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_random_64_char_hex_string_here
API_KEY_SALT=another_random_string

ENVIRONMENT=development

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=3600

# CORS — add your Vercel URL when deploying
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
